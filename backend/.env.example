PORT=5000

# ── MongoDB Connection ──────────────────────────────────────────────────────
# Option A: Local MongoDB
MONGODB_URI=mongodb://localhost:27017/studies_lms

# Option B: MongoDB Atlas (cloud)
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/studies_lms?retryWrites=true&w=majority
# ────────────────────────────────────────────────────────────────────────────

JWT_SECRET=change_this_in_production
JWT_REFRESH_SECRET=change_this_refresh_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
NODE_ENV=development
CLIENT_URL=http://localhost:5173
